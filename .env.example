# AutoVibe Configuration Example
# Copy this file to .env and fill in your values

# LLM Configuration
AUTOVIBE_LLM__PROVIDER=ollama
AUTOVIBE_LLM__MODEL=qwen3:8b
AUTOVIBE_LLM__BASE_URL=http://localhost:11434
AUTOVIBE_LLM__API_KEY=
AUTOVIBE_LLM__TIMEOUT=300

# Executor Configuration
AUTOVIBE_EXECUTOR__TIMEOUT=30
AUTOVIBE_EXECUTOR__MAX_MEMORY_MB=512
AUTOVIBE_EXECUTOR__USE_VENV=true

# Memory Configuration
AUTOVIBE_MEMORY__ENABLED=true
AUTOVIBE_MEMORY__DECAY_RATE=0.95
AUTOVIBE_MEMORY__MAX_ENTRIES=1000

# Cost Tracking
AUTOVIBE_COST__ENABLED=true
AUTOVIBE_COST__PRICE_PER_1K_TOKENS=0.0

# Strategy
AUTOVIBE_STRATEGY__DEFAULT=deep
AUTOVIBE_STRATEGY__MAX_ITERATIONS=5

# Dashboard
AUTOVIBE_DASHBOARD__ENABLED=true
AUTOVIBE_DASHBOARD__HOST=0.0.0.0
AUTOVIBE_DASHBOARD__PORT=7891

# Tokens
AUTOVIBE_TOKENS__MAX_CONTEXT_TOKENS=60000
AUTOVIBE_TOKENS__CHECKPOINT_INTERVAL=3

# Flask Secret Key (auto-generated if not set)
FLASK_SECRET_KEY=

# Custom Config Path
AUTOVIBE_CONFIG=
